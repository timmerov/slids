program:
  classes:
    class Box  file=boxhdr.slh tok=0
      ctor (no body)
      dtor (no body)
      field mode_ Box:Mode = <expr>
      field ticks_ int = <expr>
      enum Mode
        value kIdle
        value kRunning
        value kDone
      method start() -> void (no body)
      method tick() -> void (no body)
      method report() -> int (no body)
