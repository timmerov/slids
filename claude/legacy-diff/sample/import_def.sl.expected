program:
  functions:
    function printHelloWorld() -> void  file=import_decl.slh tok=1
    function printGoodbye() -> void  file=import_decl.slh tok=6
    function printHelloWorld() -> void  file=import_def.sl tok=99
    function printGoodbye() -> void  file=import_def.sl tok=120
  globals:
    global query static  file=import_def.sl tok=3
      field who_  = <expr>
    global <unnamed> static  file=import_def.sl tok=12
      field what_  = <expr>
    global <unnamed> static  file=import_def.sl tok=17
      field where_ int = <expr>
    global query lazy  file=import_def.sl tok=22
      field when_  = <expr>
      ctor
      dtor
    global state lazy  file=import_def.sl tok=51
      field hellos_  = <expr>
      field goodbyes_  = <expr>
      ctor
      dtor
  imported_headers:
    import_decl.slh
