program:
  functions:
    function printHelloWorld() -> void  file=import_decl.slh tok=1
    function printGoodbye() -> void  file=import_decl.slh tok=6
    function main() -> int32  file=import_test.sl tok=4
  globals:
    global query static imported(import_decl)  file=import_decl.slh tok=10
      field who_  = <expr>
    global <unnamed> static imported(import_decl)  file=import_decl.slh tok=19
      field what_  = <expr>
    global <unnamed> static imported(import_decl)  file=import_decl.slh tok=24
      field where_ int
    global query lazy imported(import_decl)  file=import_decl.slh tok=27
      field when_  = <expr>
      ctor (no body)
      dtor (no body)
  imported_headers:
    import_decl.slh
