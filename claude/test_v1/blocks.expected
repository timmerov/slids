== test14: naked break in while ==
while s=0
while s=1
after-while s=1
== test15: naked continue in while ==
while u=1
body u=1
while u=2
while u=3
body u=3
after-while
== test16: break 1 in switch in for exits the for ==
for v=0
after-switch v=0
for v=1
  case 1, break 1
after-for
== test17: continue 1 in switch in for skips iteration ==
for w=0
after-switch w=0
for w=1
  case 1, continue 1
for w=2
after-switch w=2
after-for
== test18: break 2 counts loops only, ignores switch ==
outer x=0
  inner y=0
  after-switch y=0
  inner y=1
    case 1, break 2
after-outer
== test19: continue 2 counts loops only, ignores switch ==
outer xa=0
  inner ya=0
  after-switch ya=0
  inner ya=1
    case 1, continue 2
outer xa=1
  inner ya=0
  after-switch ya=0
  inner ya=1
    case 1, continue 2
after-outer
