== test01: for default name break ==
for i=0
after-if i=0
for i=1
after-for
== test02: for default name continue ==
for ic=0
body ic=0
for ic=1
for ic=2
body ic=2
after-for
== test03: while default name break ==
while n=0
while n=1
after-while n=1
== test04: while default name continue ==
while m=1
body m=1
while m=2
while m=3
body m=3
after-while
== test05: bottom-while default name break ==
bw b=0
bw b=1
after-bw b=2
== test06: switch default name break ==
case 2
after-switch
== test07: nested fors, inner default vs outer label ==
outer o=0
  inner j=0
  after-if j=0
  inner j=1
after-inner o=0
outer o=1
  inner j=0
  after-if j=0
  inner j=1
after-inner o=1
outer o=2
  inner j=0
  after-if j=0
  inner j=1
after-inner o=2
after-outer
== test08: nested fors, inner break to outer label ==
outer oo=0
  inner jj=0
  after-if jj=0
  inner jj=1
  after-if jj=1
  inner jj=2
  after-if jj=2
outer oo=1
  inner jj=0
  after-if jj=0
  inner jj=1
after-outer
== test09: for-tuple default name break ==
t=10
t=20
after-for-tuple
== test10: switch inside for, break switch only kills switch ==
k=0
  case 0
after-switch k=0
k=1
  case 1
after-switch k=1
after-for
== test11: naked break in for ==
for p=0
after-if p=0
for p=1
after-for
== test12: naked continue in for ==
for q=0
body q=0
for q=1
for q=2
body q=2
after-for
== test13: naked break in switch inside for ==
r=0
  case 0
after-switch r=0
r=1
