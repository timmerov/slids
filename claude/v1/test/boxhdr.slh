/*
header for the headerfields regression test.

Box's fields — including an enum-typed one — and its nested enum
are declared here; the method bodies live in headerfields.sl.
*/

Box(
    Mode mode_ = kIdle,
    int ticks_ = 0
) {
    enum Mode (
        kIdle,
        kRunning,
        kDone
    );

    _();
    ~();
    void start();
    void tick();
    int report();
}
