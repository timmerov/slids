/*
test import and linked files.
this is the library header file.

everything declared in this source file is public.
public members are visible outside this source file.

declarations only.
no definitions here.
the definitions are in the library source file.

globals in an imported header are declarations, not definitions.
exactly one source file must define the globals declared here.
the initializer is optional.
but must match the value in the defining source file.
*/

/*
claude says:

this header declares; library.sl defines. the two rules that bind this file:

NO DEFINITIONS HERE. checked in the PARSER (grammar rejectBodyInHeader), not later —
by resolve the tree also holds SYNTHESIZED definitions (the default ctor/dtor/copy/
move/swap) stamped with this file's id, and no later stage could tell those from a
body someone typed here. it only bites where a declaration and a definition are
SEPARABLE things: a function / method / hook / operator. the alias / enum below stay,
because for those the declaration IS the definition — nothing to separate.

THIS HEADER REQUIRES A SIBLING library.sl. even for a pod class, even if it were
empty. someone has to emit the synthesized members exactly once, and "the .sl with
the same base name" is the only answer that every TU computes identically.

the classes here cover the axes that matter, not just the happy path:
  Animal      hooks + an op= + a method, all DECLARED here and DEFINED in the
              sibling. proves the ban is on ADDING an implicit member, not defining
              one — `Animal:_(){}` over there is legal precisely because `_();` is here.
  Space       a namespace: its member fn and its nested Vegetable must mangle by
              SCOPE PATH, since a symbol may never be a function of which TU minted it.
  Vegetable   hooks declared here, ctor defined in a BLOCK re-open and dtor in the
              EXTERNAL form over in the sibling — a ctor/dtor is a method with
              restrictions, so every method syntax has to reach it.
  NoCtor      declares NO implicit member, so every source-side attempt to add one is
              a compile error. that is its only job; it is never instantiated.
*/

alias Integer = int;
enum Color ( kRed, kGreeen, kBlue );

void hello_world();

/* OVERLOADED across the seam: two signatures, declared here, defined in library.sl,
   called with both arities in consumer.sl. This is the case the old per-TU entry-id
   overload suffix could not link — the definer and the importer numbered their entries
   differently, so `@add.N` disagreed. Itanium mangling makes the symbol a function of
   the signature alone (`_Z3addu3int` vs `_Z3addu3intu3int`), identical in every TU. */
int add(int a);
int add(int a, int b);

/* a SAME-ARITY overload discriminated by TYPE (not count): the symbols differ only in
   the mangled parameter type (`_Z4picku3int` vs `_Z4picku5int64`), so this is what
   proves two TUs agree on the TYPE encoding, not just the arity. */
int pick(int x);
int pick(int64 x);

/* a TUPLE in the signature — the special case Itanium can't spell. It reaches the
   mangler as `Pu<len>tuple2$int$int` (a pointer, since a tuple can't be passed by
   value), and both TUs must mint that identical vendor form. */
int pairsum((int, int)^ p);

/* the two slids pointer-like types must take DISTINCT codes: `^` -> Itanium `P`
   (`int*`), `[]` -> Itanium `R` (`int&`). Sharing `P` made these two legal overloads
   mint ONE symbol (`_Z5probePu3int` twice) — invalid IR. They are a valid overload
   set, so this file DEFINES both and consumer.sl calls each. */
int probe(int^ r);
int probe(int[] it);

Animal(int a, int b) {
    _(); ~();
    op=(Animal^ rhs);
    void print();
    int sum(int x);            /* an OVERLOADED METHOD across the seam — same test */
    int sum(int x, int y);
}

Space {
    alias Float = float;
    enum Result ( kSuccess, kFailure );

    void goodbye_world();

    Vegetable(int a, int b) {
        _(); ~();
        void print();
    }
}

/* Bird's hooks and method are declared here like Animal's, but DEFINED in bird.sl —
   not in the sibling. that is the "each class can have its own source file" case, and
   it is a different code path from Animal: library.sl still emits Bird's SYNTHESIZED
   members (it is the sibling), so its complete @Bird__$ctor calls a `__impl` that
   another object file defines. that call needs a `declare`; without one, library.ll is
   invalid IR that slidsc emits happily and only llc rejects. */
Bird(int a, int b) {
    _(); ~();
    void chirp();
}

global Query(who_ = 1) { }
global what_ = 2;
int where_;
global Query(when_ = 4) {
    _();
    ~();
}

/* MUTATED across the seam: written in one TU and read in another — the real proof the
   two TUs address ONE storage cell, not two symbols that happened not to collide. */
int shared_ = 10;
void bump_shared();

/* a COMPOUND (array) global across the seam: the lone-compound lazy path, which the
   DEFINING TU constructs/destructs while an importer only declares + touches. (The
   `global` keyword is required for an array — the bare form is scalar-only.) */
global int nums[3];

/* defined in bird.sl — a NON-SIBLING source. any one .sl may define a header global. */
int from_bird = 77;

/* the header's initializer is a cross-check: a definition that gives a DIFFERENT value
   is an error (verified by the negative in library.sl). This decl is never defined or
   read in the normal build — a header value with no definer is a harmless external. */
int mismatch_ = 2;

/* incomplete class */
String(...) {
    _(); ~();
    void set(char[] s);
    char[] get();
    int tag();
}

/* a second incomplete class that stresses EVERY FIELD KIND the completer's @Mix__$ctor
   must default-construct on behalf of an importer that cannot see the layout: a primitive
   WITH a default, a primitive with NONE (the ctor must zero it), a by-value CLASS field
   (constructed recursively, its own defaults/zeros filled), and an ARRAY field (each
   element zeroed). The consumer only ever calls the getters — it never names a field. */
Mix(...) {
    _(); ~();
    int a();       // primitive field with a default
    int b();       // primitive field with NO default -> 0
    int s();       // a by-value class field, default-constructed recursively
    int r(int i);  // an array field element, zeroed
}

/* a POD incomplete class — NO ctor/dtor hooks. An importer must STILL route construction
   (and destruction) through @Flat__$ctor / @Flat__$dtor to fill the fields it cannot see:
   the "trivial class, construct nothing" shortcut a normal POD gets does NOT apply when the
   layout is hidden, or the importer reads uninitialized storage. */
Flat(...) { int a(); int b(); }

NoCtor(int a_) { }

/* no definitions in a header file. a declaration and its definition are separable for
   a function / method / hook / operator, so the header may only declare them. (For a
   const / enum / alias the declaration IS the definition, so those stay.) each case
   carries its own class declaration: the runner uncomments ONE block at a time, and a
   Wrong left declared in the live header would have hooks no source ever defines. */

//-EXPECT-ERROR: A header file holds declarations only
//Wrong(int a_) {
//    _(); ~();
//}
//Wrong:_() { __println("compile error"); }

//-EXPECT-ERROR: A header file holds declarations only
//Wrong(int a_) {
//    _(); ~();
//}
//Wrong:~() { __println("compile error"); }

//-EXPECT-ERROR: A header file holds declarations only
//Wrong(int a_) {
//    op=(Wrong^ rhs);
//}
//Wrong:op=(Wrong^ rhs) { __println("compile error"); }

//-EXPECT-ERROR: A header file holds declarations only
//Wrong(int a_) {
//    void wrong();
//}
//void Wrong:wrong() { __println("compile error"); }

/* the in-class form is the same violation — a body is a body wherever it is written. */
//-EXPECT-ERROR: A header file holds declarations only
//Inline(int a_) {
//    void m() { __println("compile error"); }
//}
